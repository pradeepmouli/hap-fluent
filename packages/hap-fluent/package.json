{
  "name": "hap-fluent",
  "version": "0.3.0",
  "description": "Fluent, strongly-typed wrapper for HAP-NodeJS services and characteristics.",
  "license": "Apache-2.0",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./interceptors": {
      "types": "./dist/interceptors.d.ts",
      "import": "./dist/interceptors.js"
    },
    "./type-guards": {
      "types": "./dist/type-guards.d.ts",
      "import": "./dist/type-guards.js"
    },
    "./type-utils": {
      "types": "./dist/type-utils.d.ts",
      "import": "./dist/type-utils.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsgo --build",
    "lint": "oxlint src/",
    "lint:eslint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "format:prettier": "prettier --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsgo --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "dependencies": {
    "camelcase": "^9.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "hap-nodejs": "^0.14.3",
    "homebridge": "^1.11.4",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "ts-node": "^10.9.2",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "hap-nodejs": ">=0.13.0",
    "homebridge": ">=1.11.0"
  },
  "size-limit": []
}
