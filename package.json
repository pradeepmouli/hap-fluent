{
  "name": "hap-fluent-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript monorepo for HAP-Fluent - Type-safe wrapper for Homebridge HAP-NodeJS",
  "keywords": [
    "accessories",
    "characteristics",
    "fluent-api",
    "hap",
    "hap-nodejs",
    "homekit",
    "iot",
    "services",
    "smart-home",
    "type-safe"
  ],
  "homepage": "https://pradeepmouli.github.io/hap-fluent/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/hap-fluent/issues"
  },
  "license": "Apache-2.0",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter '!hap-codegen' run build",
    "test": "pnpm -r --filter '!hap-codegen' run test",
    "lint": "oxlint .",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "oxfmt",
    "format:prettier": "prettier --write .",
    "format:check": "oxfmt --check",
    "type-check": "pnpm -r --filter '!hap-codegen' run type-check",
    "clean": "pnpm -r --filter '!hap-codegen' run clean",
    "docs:dev": "pnpm --filter @hap-fluent/docs dev",
    "docs:build": "pnpm --filter @hap-fluent/docs build",
    "dev": "pnpm -r --filter '!hap-codegen' --parallel run dev",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "homebridge-lib": "^7.3.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@to-skills/vitepress": "^0.2.25",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript/native-preview": "7.0.0-dev.20260426.1",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "type-fest": "^5.6.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^1.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.32.0"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "overrides": {
      "glob": "^11.0.0"
    }
  }
}
